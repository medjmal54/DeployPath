<div class="playground-wrapper rounded-3 p-4 my-4 border">
    <div class="playground-header d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom">
        <h3 class="playground-title h5 fw-bold mb-0 d-flex align-items-center gap-2">
            <span>☸️</span> Kubernetes Cluster Simulator
        </h3>
        <span class="playground-badge">Interactive</span>
    </div>

    <div class="k8s-cluster-visualizer d-flex flex-column gap-4">
        <!-- Nodes Container -->
        <div class="row g-3">
            @foreach (var node in Nodes)
            {
                <div class="col-md-4">
                    <div class="k8s-node-box rounded-2 p-3 d-flex flex-column gap-2" style="background-color: var(--surface-color); border: 1px solid var(--border-color);">
                        <div class="k8s-node-title text-center text-uppercase small fw-bold pb-1" style="color: var(--text-muted); border-bottom: 1px solid var(--border-light);">@node.Name</div>
                        <div class="k8s-pods-grid d-flex flex-wrap gap-2 justify-content-center align-items-center" style="min-height: 80px;">
                            @foreach (var pod in node.Pods)
                            {
                                <div class="k8s-pod-node d-flex align-items-center justify-content-center rounded-2 position-relative" style="width: 38px; height: 38px; font-size: 0.65rem; font-weight: 700; @(pod.IsSpinningUp ? "border-color: var(--warning); color: var(--warning); background-color: rgba(245,158,11,0.1);" : "border-color: var(--success); color: var(--success); background-color: rgba(34,197,94,0.1);")" title="@pod.Name">
                                    @pod.ShortName
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Scaling Control -->
        <div class="k8s-scaling-control d-flex justify-content-between align-items-center rounded-2 p-3" style="background-color: var(--surface-color); border: 1px solid var(--border-light);">
            <div class="d-flex align-items-center gap-2">
                <span class="fw-semibold">Replicas:</span>
                <span class="k8s-slider-value" style="font-family: var(--font-mono); font-weight: 700; font-size: 1.1rem;">@ReplicaCount</span>
            </div>
            <div class="k8s-slider-group d-flex align-items-center gap-3">
                <input type="range" class="k8s-slider form-range" style="width: 150px;" min="1" max="12" step="1" @bind="ReplicaCount" @bind:event="oninput" @onchange="ScalePods">
                <button class="btn btn-sm text-white" style="background-color: var(--primary-accent);" @onclick="ScalePods">Apply</button>
            </div>
        </div>
    </div>
</div>

@code {
    private int _replicaCount = 3;
    private int ReplicaCount
    {
        get => _replicaCount;
        set => _replicaCount = value;
    }

    private List<K8sNode> Nodes = new()
    {
        new K8sNode("Node-1"),
        new K8sNode("Node-2"),
        new K8sNode("Node-3"),
    };

    private void ScalePods()
    {
        var allPods = new List<K8sPod>();
        for (int i = 0; i < ReplicaCount; i++)
        {
            allPods.Add(new K8sPod($"pod-{i + 1}", $"P{i + 1}", false));
        }

        foreach (var node in Nodes) node.Pods.Clear();
        for (int i = 0; i < allPods.Count; i++)
        {
            Nodes[i % Nodes.Count].Pods.Add(allPods[i]);
        }
    }

    protected override void OnInitialized()
    {
        ScalePods();
    }
}